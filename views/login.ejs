<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Divine Insights</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>𐤃𐤉𐤅𐤉</h1>
        <p>Access Your Account</p>
    </header>
    <nav>
        <a href="/">Home</a>
        <a href="/register" class="nav-green-flame">Register</a>
    </nav>
    <main>
        <form action="/login" method="POST" class="bounce-in">
            <h2>Login to Divine Insights</h2>
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required placeholder="Enter your username">

            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required placeholder="Enter your password">

            <button type="submit">Login</button>
            <% if (typeof error !== 'undefined') { %>
                <p style="color: var(--blood-red); font-weight: bold;"><%= error %></p>
            <% } %>
            <p style="text-align: center; margin-top: 1rem;">Don't have an account? <a href="/register">Register here</a></p>
        </form>
    </main>
    <script src="/script.js"></script>
</body>
</html>