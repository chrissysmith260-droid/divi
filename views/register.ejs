<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Divine Insights</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>𐤃𐤉𐤅𐤉</h1>
        <p>Create Your Account</p>
    </header>
    <nav>
        <a href="/">Home</a>
        <a href="/login" class="nav-green-flame">Login</a>
    </nav>
    <main>
        <form action="/register" method="POST" class="bounce-in">
            <h2>Register for Divine Insights</h2>
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required placeholder="Choose your username">

            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required placeholder="Enter your email">

            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required placeholder="Create a secure password">

            <button type="submit">Register</button>
            <% if (typeof error !== 'undefined') { %>
                <p style="color: var(--blood-red); font-weight: bold;"><%= error %></p>
            <% } %>
            <p style="text-align: center; margin-top: 1rem;">Already have an account? <a href="/login">Login here</a></p>
        </form>
    </main>
    <script src="/script.js"></script>
</body>
</html>