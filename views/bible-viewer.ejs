<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bible Viewer - Divine Insights</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>Large Print Bible Viewer</h1>
    </header>
    <nav>
        <a href="/">Home</a>
        <a href="/sermon-generator">Sermon Generator</a>
        <a href="/bible-viewer">Bible Viewer</a>
    </nav>
    <main>
        <form action="/get-verse" method="POST">
            <label for="religion">Religion:</label>
            <select id="religion" name="religion" required>
                <% religions.forEach(religion => { %>
                    <option value="<%= religion %>"><%= religion.charAt(0).toUpperCase() + religion.slice(1) %></option>
                <% }); %>
            </select>

            <label for="book">Book:</label>
            <select id="book" name="book" required>
                <option value="genesis">Genesis</option>
                <option value="quran">Quran</option>
                <option value="wheel of the year">Wheel of the Year</option>
                <option value="elements">Elements</option>
            </select>

            <label for="chapter">Chapter:</label>
            <input type="number" id="chapter" name="chapter" min="1" required>

            <label for="verse">Verse:</label>
            <input type="number" id="verse" name="verse" min="1" required>

            <button type="submit">View Verse</button>
        </form>
    </main>
</body>
</html>