<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tarot Guide - Divine Insights</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>𐤃𐤉𐤅𐤉</h1>
        <p>Mystical Tarot Guide</p>
    </header>
    <nav>
        <a href="/">Home</a>
        <a href="/sermon-generator" class="nav-orange-fire">Sermon Generator</a>
        <a href="/bible-viewer" class="nav-flame">Bible Viewer</a>
        <a href="/my-sermons" class="nav-flame">My Sermons</a>
        <a href="/notes" class="nav-flame">Notes</a>
        <a href="/tarot" class="nav-flame">Tarot Guide</a>
        <a href="/ai-tools" class="nav-flame">AI Tools</a>
        <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="nav-flame">Logout</button>
        </form>
    </nav>
    <main class="slide-up">
        <h2>Major Arcana</h2>
        <div class="tarot-grid">
            <% tarotCards.majorArcana.forEach(card => { %>
                <div class="tarot-card">
                    <h3><%= card.name %></h3>
                    <p><%= card.meaning %></p>
                </div>
            <% }); %>
        </div>

        <h2>Minor Arcana - Wands</h2>
        <div class="tarot-grid">
            <% tarotCards.minorArcana.wands.forEach(card => { %>
                <div class="tarot-card">
                    <h3><%= card.name %></h3>
                    <p><%= card.meaning %></p>
                </div>
            <% }); %>
        </div>

        <h2>Minor Arcana - Cups</h2>
        <div class="tarot-grid">
            <% tarotCards.minorArcana.cups.forEach(card => { %>
                <div class="tarot-card">
                    <h3><%= card.name %></h3>
                    <p><%= card.meaning %></p>
                </div>
            <% }); %>
        </div>

        <h2>Minor Arcana - Swords</h2>
        <div class="tarot-grid">
            <% tarotCards.minorArcana.swords.forEach(card => { %>
                <div class="tarot-card">
                    <h3><%= card.name %></h3>
                    <p><%= card.meaning %></p>
                </div>
            <% }); %>
        </div>

        <h2>Minor Arcana - Pentacles</h2>
        <div class="tarot-grid">
            <% tarotCards.minorArcana.pentacles.forEach(card => { %>
                <div class="tarot-card">
                    <h3><%= card.name %></h3>
                    <p><%= card.meaning %></p>
                </div>
            <% }); %>
        </div>
    </main>
    <script src="/script.js"></script>
</body>
</html>