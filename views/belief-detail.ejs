<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- belief.name %> - DiVi: The Belief Master</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f5f5;
            color: #333;
        }

        .header-gradient {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .back-link {
            display: inline-block;
            color: white;
            text-decoration: none;
            margin-bottom: 20px;
            padding: 8px 16px;
            background: rgba(255,255,255,0.2);
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            background: rgba(255,255,255,0.3);
        }

        h1 {
            font-size: 2.5em;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .overview {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
        }

        .overview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 15px;
        }

        .overview-item {
            background: rgba(255,255,255,0.15);
            padding: 15px;
            border-radius: 6px;
        }

        .overview-label {
            font-weight: 600;
            opacity: 0.8;
            margin-bottom: 5px;
            font-size: 0.9em;
        }

        .overview-value {
            font-size: 1.2em;
            font-weight: 500;
        }

        .overview-text {
            font-size: 1.05em;
            line-height: 1.6;
            margin-top: 15px;
            opacity: 0.95;
        }

        /* Main Content */
        .content {
            background: white;
            margin-top: 40px;
            margin-bottom: 40px;
        }

        .section {
            padding: 40px;
            border-bottom: 1px solid #e0e0e0;
        }

        .section:last-child {
            border-bottom: none;
        }

        h2 {
            color: #667eea;
            font-size: 1.8em;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        h3 {
            color: #764ba2;
            font-size: 1.2em;
            margin-top: 20px;
            margin-bottom: 10px;
        }

        h3:first-child {
            margin-top: 0;
        }

        p {
            line-height: 1.8;
            margin-bottom: 15px;
            color: #555;
        }

        ul, ol {
            margin-left: 25px;
            margin-bottom: 15px;
        }

        li {
            margin-bottom: 12px;
            line-height: 1.6;
            color: #555;
        }

        li strong {
            color: #667eea;
        }

        .highlight-box {
            background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
            border-left: 4px solid #667eea;
            padding: 20px;
            border-radius: 6px;
            margin: 20px 0;
        }

        .two-column {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 20px;
        }

        .column {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
        }

        .column h3 {
            margin-top: 0;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            border-bottom: 2px solid #e0e0e0;
        }

        .tab-button {
            padding: 10px 20px;
            background: none;
            border: none;
            border-bottom: 2px solid transparent;
            cursor: pointer;
            font-weight: 600;
            color: #999;
            transition: all 0.3s ease;
        }

        .tab-button:hover {
            color: #667eea;
        }

        .tab-button.active {
            color: #667eea;
            border-bottom-color: #667eea;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .resource-box {
            background: #f0f8ff;
            border-left: 4px solid #667eea;
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
        }

        .resource-box h4 {
            color: #667eea;
            margin-bottom: 10px;
        }

        .resource-box p {
            margin: 5px 0;
        }

        .footer-links {
            background: #f5f5f5;
            padding: 30px 20px;
            text-align: center;
        }

        .footer-links a {
            display: inline-block;
            margin: 10px;
            padding: 10px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .footer-links a:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102,126,234,0.3);
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 1.8em;
            }

            h2 {
                font-size: 1.4em;
            }

            .section {
                padding: 20px;
            }

            .overview-grid {
                grid-template-columns: 1fr;
            }

            .two-column {
                grid-template-columns: 1fr;
            }

            .tabs {
                flex-direction: column;
            }

            .tab-button {
                width: 100%;
                border-bottom: 2px solid #e0e0e0 !important;
            }
        }
    </style>
</head>
<body>
    <div class="header-gradient">
        <div class="container">
            <a href="/beliefs" class="back-link">← Back to All Beliefs</a>
            <h1><%- belief.name %></h1>
            <div class="overview">
                <div class="overview-grid">
                    <div class="overview-item">
                        <div class="overview-label">Region of Origin</div>
                        <div class="overview-value"><%- belief.region %></div>
                    </div>
                    <div class="overview-item">
                        <div class="overview-label">Followers</div>
                        <div class="overview-value"><%- belief.followers %></div>
                    </div>
                    <div class="overview-item">
                        <div class="overview-label">Founded</div>
                        <div class="overview-value"><%- belief.founded %></div>
                    </div>
                </div>
                <div class="overview-text">
                    <%- belief.overview %>
                </div>
            </div>
        </div>
    </div>

    <div class="content">
        <div class="container">
            <!-- Core Teachings -->
            <% if (belief.coreTeachings) { %>
            <div class="section">
                <h2>🎯 Core Teachings</h2>
                <ul>
                    <% belief.coreTeachings.forEach(teaching => { %>
                        <li><%- teaching %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>

            <!-- Sacred Texts -->
            <% if (belief.sacredTexts) { %>
            <div class="section">
                <h2>📖 Sacred Texts</h2>
                <% if (belief.sacredTexts.primary) { %>
                    <h3>Primary Texts</h3>
                    <p><strong><%- belief.sacredTexts.primary %></strong></p>
                <% } %>
                
                <% if (belief.sacredTexts.secondary || belief.sacredTexts.keyBooks || belief.sacredTexts.shruti) { %>
                    <h3>Additional Scriptures</h3>
                    <ul>
                        <% 
                            const textArray = belief.sacredTexts.secondary || belief.sacredTexts.keyBooks || belief.sacredTexts.shruti || [];
                            textArray.forEach(text => { 
                        %>
                            <li><%- typeof text === 'string' ? text : text.name || text %></li>
                        <% }); %>
                    </ul>
                <% } %>
                
                <% if (belief.sacredTexts.smriti) { %>
                    <h3>Secondary Texts (Smriti)</h3>
                    <ul>
                        <% belief.sacredTexts.smriti.forEach(text => { %>
                            <li><%- text %></li>
                        <% }); %>
                    </ul>
                <% } %>
            </div>
            <% } %>

            <!-- Deities / Spiritual Concepts -->
            <% if (belief.deities) { %>
            <div class="section">
                <h2>✨ Sacred Beings & Concepts</h2>
                <% if (belief.deities.trinity) { %>
                    <h3>The Divine Trinity</h3>
                    <ul>
                        <% belief.deities.trinity.forEach(deity => { %>
                            <li><%- deity %></li>
                        <% }); %>
                    </ul>
                <% } %>
                
                <% if (belief.deities.others) { %>
                    <h3>Other Important Figures</h3>
                    <ul>
                        <% belief.deities.others.forEach(deity => { %>
                            <li><%- deity %></li>
                        <% }); %>
                    </ul>
                <% } %>
                
                <% if (belief.deities.mainDeities) { %>
                    <h3>Principal Deities</h3>
                    <ul>
                        <% belief.deities.mainDeities.forEach(deity => { %>
                            <li><%- deity %></li>
                        <% }); %>
                    </ul>
                <% } %>
            </div>
            <% } %>

            <!-- Philosophical Schools / Traditions -->
            <% if (belief.majorPhilosophies || belief.majorTraditions || belief.types) { %>
            <div class="section">
                <h2>🏛️ Major Schools & Traditions</h2>
                <ul>
                    <% 
                        const traditions = belief.majorPhilosophies || belief.majorTraditions || belief.types || [];
                        traditions.forEach(tradition => { 
                    %>
                        <li><%- typeof tradition === 'string' ? tradition : tradition.name || tradition %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>

            <!-- Special Concepts -->
            <% if (belief.eightfoldPath || belief.fivePillars || belief.lifeStages || belief.wheelOfTheYear) { %>
            <div class="section">
                <h2>⭐ Central Practices & Paths</h2>
                
                <% if (belief.fivePillars) { %>
                    <h3>The Five Pillars of Islam</h3>
                    <ol>
                        <% belief.fivePillars.forEach(pillar => { %>
                            <li><%- pillar %></li>
                        <% }); %>
                    </ol>
                <% } %>

                <% if (belief.eightfoldPath) { %>
                    <h3>The Noble Eightfold Path</h3>
                    <ol>
                        <% belief.eightfoldPath.forEach(path => { %>
                            <li><%- path %></li>
                        <% }); %>
                    </ol>
                <% } %>

                <% if (belief.lifeStages) { %>
                    <h3>Four Life Stages (Ashramas)</h3>
                    <ol>
                        <% belief.lifeStages.forEach(stage => { %>
                            <li><%- stage %></li>
                        <% }); %>
                    </ol>
                <% } %>

                <% if (belief.wheelOfTheYear) { %>
                    <h3>Wheel of the Year</h3>
                    <ul>
                        <% belief.wheelOfTheYear.forEach(season => { %>
                            <li><%- season %></li>
                        <% }); %>
                    </ul>
                <% } %>
            </div>
            <% } %>

            <!-- Key Practices -->
            <% if (belief.keyPractices) { %>
            <div class="section">
                <h2>🙏 Key Practices</h2>
                <ul>
                    <% belief.keyPractices.forEach(practice => { %>
                        <li><%- practice %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>

            <!-- Festivals & Celebrations -->
            <% if (belief.festivals) { %>
            <div class="section">
                <h2>🎉 Festivals & Holy Days</h2>
                <ul>
                    <% belief.festivals.forEach(festival => { %>
                        <li><%- festival %></li>
                    <% }); %>
                </ul>
            </div>
            <% } %>

            <!-- Cultural Context -->
            <% if (belief.culturalContext) { %>
            <div class="section">
                <h2>🌍 Cultural Significance & Context</h2>
                <div class="highlight-box">
                    <%- belief.culturalContext %>
                </div>
            </div>
            <% } %>

            <!-- Resources -->
            <% if (belief.resources) { %>
            <div class="section">
                <h2>📚 Learning Resources & Exploration</h2>
                <div class="resource-box">
                    <h4>Where to Learn</h4>
                    <p><%- belief.resources.learn %></p>
                </div>
                <div class="resource-box">
                    <h4>How to Explore</h4>
                    <p><%- belief.resources.explore %></p>
                </div>
            </div>
            <% } %>

            <!-- Modern Expression -->
            <% if (belief.modernExpression) { %>
            <div class="section">
                <h2>🔮 Modern Expression</h2>
                <p><%- belief.modernExpression %></p>
            </div>
            <% } %>
        </div>
    </div>

    <div class="footer-links">
        <a href="/beliefs">📚 Back to All Beliefs</a>
        <a href="/">🏠 Home</a>
        <% if (user && user.isPremium) { %>
            <a href="/daily-divination">🔮 Daily Divination</a>
        <% } %>
    </div>
</body>
</html>
