<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Sermons - Divine Insights</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header>
        <h1>𐤃𐤉𐤅𐤉</h1>
        <p>Your Sermon Archive</p>
    </header>
    <nav>
        <a href="/">Home</a>
        <a href="/sermon-generator" class="nav-orange-fire">New Sermon</a>
        <a href="/bible-viewer" class="nav-flame">Bible Viewer</a>
        <a href="/my-sermons" class="nav-flame">My Sermons</a>
        <a href="/notes" class="nav-flame">Notes</a>
        <% if (user && user.isPremium) { %>
            <a href="/tarot" class="nav-flame">Tarot Guide</a>
            <a href="/ai-tools" class="nav-flame">AI Tools</a>
        <% } else { %>
            <a href="/upgrade" class="nav-flame">Upgrade</a>
        <% } %>
        <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="nav-flame">Logout</button>
        </form>
    </nav>
    <main class="slide-up">
        <h2>Your Sermon Library</h2>
        <% if (sermons.length === 0) { %>
            <p>You haven't saved any sermons yet. <a href="/sermon-generator">Generate one now!</a></p>
        <% } else { %>
            <ul class="sermon-list">
                <% sermons.forEach(sermon => { %>
                    <li>
                        <h3><%= sermon.title %></h3>
                        <p>Created: <%= new Date(sermon.created_at).toLocaleDateString() %></p>
                        <a href="/edit-sermon/<%= sermon.id %>">✏️ Edit</a>
                    </li>
                <% }); %>
            </ul>
        <% } %>
    </main>
    <script src="/script.js"></script>
    <script type="module" src="/speed-insights-init.js"></script>
</body>
</html>